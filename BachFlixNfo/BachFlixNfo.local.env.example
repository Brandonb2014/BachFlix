# Copy this file to BachFlixNfo.local.env and fill in local values.
# BachFlixNfo.local.env is ignored by git.

TMDB_API_KEY=
TMDB_LIST_ID=
TMDB_SESSION_ID=
YOUTUBE_API_KEY=
# Audio Censor / WhisperX
AUDIO_CENSOR_WHISPERX_PATH=
AUDIO_CENSOR_WHISPERX_MODEL=small
AUDIO_CENSOR_WHISPERX_DEVICE=cpu
AUDIO_CENSOR_WHISPERX_COMPUTE_TYPE=int8
AUDIO_CENSOR_WHISPERX_LANGUAGE=en
AUDIO_CENSOR_CENSORED_AUDIO_CODEC=flac
AUDIO_CENSOR_SUBTITLE_REPLACEMENT=asterisks
AUDIO_CENSOR_KEEP_WORK_FILES=false
